{
  "name": "mole-option-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Wave 11 MVP — React + Vite + TS SPA with three panels (Trader, IndexerState, Keeper Console). Mock data feed today; wave 12 will wire to keeper-rpc + Solana RPC.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "keeper:setup": "node scripts/keeper-devnet.mjs setup",
    "keeper": "node scripts/keeper-devnet.mjs run",
    "wasm-build": "cd .. && wasm-pack build crates/keeper-decoder --target web --features wasm"
  },
  "dependencies": {
    "@coral-xyz/borsh": "^0.30.1",
    "@noble/hashes": "^1.8.0",
    "@solana/web3.js": "^1.98.4",
    "buffer": "^6.0.3",
    "keeper-decoder": "file:../crates/keeper-decoder/pkg",
    "lightweight-charts": "^4.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "@types/node": "^22.19.19",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
