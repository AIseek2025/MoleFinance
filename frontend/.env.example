# Frontend env template — copy to `.env.local` and fill in.
# `.env.local` is gitignored; NEVER commit real RPC keys.
# Vite inlines VITE_* at build time, so anything here ends up in the
# shipped bundle. Use a domain-restricted / rate-limited key for prod.

# Solana RPC. Public devnet throttles getProgramAccounts (used by live mode);
# a dedicated provider (Helius/Triton/QuickNode) is recommended.
#   devnet example:  https://devnet.helius-rpc.com/?api-key=YOUR_KEY
VITE_RPC_URL=https://api.devnet.solana.com

# Deployed mole-option program id (devnet).
VITE_MOLE_PROGRAM_ID=EWqyK5r4MyNaewo2s6nqLmZEVt4Xcx1yNT2dfFnTSfWp

# Market PDA the single-market UI subscribes to.
# SOL-PERP (devnet, wired to the mock oracle + keeper loop):
VITE_MARKET_PDA=GTAxg2pzhMAm9h5VtwfYqpojfBDUGvo5zsjzC8ZNxvCL

# Live mode also requires the `?feed=live` URL query param to switch the
# MockFeedAdapter for the on-chain WebSocketFeedAdapter.
